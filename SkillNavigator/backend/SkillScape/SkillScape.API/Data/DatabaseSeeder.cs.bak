    private static List<ApplicationMentor> SeedMentors(ApplicationDbContext context, List<ApplicationUser> mentorUsers)
    {
        var mentorSpecializations = new Dictionary<string, (string expertise, string skills, string company, decimal rate, double rating)>
        {
            { "Sarah Chen", ("Frontend Development", "React,JavaScript,CSS,TypeScript", "TechCorp", 60, 4.9) },
            { "Rajesh Kumar", ("Backend Development", "Node.js,Python,Docker,Kubernetes", "CloudInnovate", 70, 4.7) },
            { "Emily Watson", ("Data Science", "Python,TensorFlow,pandas,scikit-learn", "DataAI Labs", 80, 4.8) },
            { "Michael Johnson", ("Full Stack Development", "React,Node.js,MongoDB,Express", "WebDev Solutions", 55, 4.6) },
            { "Priya Sharma", ("DevOps & Cloud", "AWS,Azure,Terraform,CI/CD", "CloudOps Inc", 75, 4.9) },
            { "David Lee", ("Mobile Development", "React Native,Swift,Kotlin,Flutter", "MobileWorks", 65, 4.7) },
            { "Jessica Brown", ("Web3 & Blockchain", "Solidity,Ethereum,Web3.js,Smart Contracts", "BlockchainHub", 90, 4.8) },
            { "Alex Martinez", ("System Design", "Microservices,Distributed Systems,C++", "SystemsDesign Co", 85, 4.9) },
            { "Lisa Wang", ("Security & Cryptography", "Cybersecurity,Ethical Hacking,Cryptography", "SecureCode Inc", 95, 4.8) },
            { "James Wilson", ("Game Development", "Unity,Unreal,C#,GameDesign", "GameStudio Pro", 70, 4.7) }
        };

        return mentorUsers
            .Where(u => u.Role == "Mentor")
            .Select(user =>
            {
                var (expertise, skills, company, rate, rating) = mentorSpecializations.ContainsKey(user.FullName)
                    ? mentorSpecializations[user.FullName]
                    : ("Full Stack Development", "C#,ASP.NET Core,React,SQL", "SkillScape Labs", 50, 4.5);

                return new ApplicationMentor
                {
                    Id = Guid.NewGuid().ToString(),
                    UserId = user.Id,
                    Expertise = expertise,
                    ExpertiseArea = expertise,
                    CurrentCompany = company,
                    Bio = user.Bio,
                    SkillsCsv = skills,
                    LinkedInUrl = $"https://linkedin.com/in/{user.FullName.ToLower().Replace(" ", "-")}",
                    AvailabilitySchedule = "Monday,Tuesday,Wednesday,Thursday,Friday,Saturday",
                    YearsOfExperience = new Random().Next(3, 15),
                    HourlyRate = rate,
                    SessionPrice = rate,
                    IsAvailable = true,
                    TotalSessionCount = new Random().Next(10, 100),
                    AvgRating = rating,
                    IsApproved = true,
                    ApprovedByAdminId = null,
                    ApprovedAt = DateTime.UtcNow,
                    RejectionReason = null,
                    CreatedAt = DateTime.UtcNow
                };
            }).ToList();
    }

    private static List<MentorshipProgress> SeedMentorshipProgress(ApplicationDbContext context, List<ApplicationUser> users, List<ApplicationMentor> mentors)
    {
        var mentorshipProgresses = new List<MentorshipProgress>();
        var studentUsers = users.Where(u => u.Role == "Student").ToList();
        
        if (studentUsers.Count == 0)
            return mentorshipProgresses;

        var random = new Random();
        var roadmapStages = new[] { "Basics", "Fundamentals", "Intermediate", "Advanced", "Expert", "Mastery" };
        var tasks = new[] 
        { 
            "Complete beginner course, Learn syntax, Build first project",
            "Build 2 projects, Contribute to open source, Review code",
            "Advanced design patterns, System design, Mentoring skills",
            "Build scalable application, Deploy to production, Optimize performance",
            "Write technical blog, Create course content, Lead team",
            "Expert level, Industry recognition, Multiple achievements"
        };

        // Get existing entries to avoid duplicates
        var existingEntries = context.MentorshipProgressEntries
            .Select(e => new { e.StudentId, e.RoadmapStage })
            .ToHashSet();

        // Create mentorship progress for each mentor
        foreach (var mentor in mentors)
        {
            // Each mentor mentors 2-5 students
            int studentCount = Math.Min(random.Next(2, 6), studentUsers.Count);
            var assignedStudents = studentUsers.OrderBy(x => random.Next()).Take(studentCount).ToList();

            foreach (var student in assignedStudents)
            {
                // Pick stages that don't already exist for this student
                var availableStages = roadmapStages
                    .Where(stage => !existingEntries.Contains(new { StudentId = student.Id, RoadmapStage = stage }))
                    .ToList();

                if (availableStages.Count == 0)
                    continue; // Skip if all stages already assigned to this student

                var stage = availableStages[random.Next(availableStages.Count)];
                
                mentorshipProgresses.Add(new MentorshipProgress
                {
                    Id = Guid.NewGuid().ToString(),
                    StudentId = student.Id,
                    MentorId = mentor.Id,
                    RoadmapStage = stage,
                    MentorFeedback = $"Great progress on {stage}! Keep practicing and building projects.",
                    CompletedTasks = tasks[random.Next(tasks.Length)],
                    NextMilestone = roadmapStages[(Array.IndexOf(roadmapStages, stage) + 1) % roadmapStages.Length],
                    UpdatedAt = DateTime.UtcNow.AddDays(-random.Next(0, 30))
                });

                // Track the new entry
                existingEntries.Add(new { StudentId = student.Id, RoadmapStage = stage });
            }
        }

        return mentorshipProgresses;
    }

    private static async Task SeedCareerPathsAsync(ApplicationDbContext context)
    {
        // Clear existing to refresh seeder data
        if (context.UserCareerProfiles.Any())
        {
            context.UserCareerProfiles.RemoveRange(context.UserCareerProfiles);
            await context.SaveChangesAsync();
        }
        if (context.CareerPaths.Any())
        {
            context.CareerPaths.RemoveRange(context.CareerPaths);
            await context.SaveChangesAsync();
        }

        var allPaths = new List<CareerPath>();

        // Level 1: Core Streams (6 nodes)
        var streams = new[]
        {
            new { Id = "sci-lvl1", Title = "Science Stream", Desc = "Focuses on scientific method, critical thinking, logic, and physical/biological systems.", Tags = "science,tech,healthcare", StreamType = "After10th, After12th, AfterGraduation", Icon = "flask", Color = "blue" },
            new { Id = "com-lvl1", Title = "Commerce Stream", Desc = "Focuses on business, finance, accounting, taxation, and markets.", Tags = "commerce,business,finance", StreamType = "After10th, After12th, AfterGraduation", Icon = "banknote", Color = "green" },
            new { Id = "art-lvl1", Title = "Arts & Humanities", Desc = "Focuses on human culture, creative writing, history, design, and media.", Tags = "arts,creative,humanities", StreamType = "After10th, After12th, AfterGraduation", Icon = "palette", Color = "purple" },
            new { Id = "dip-lvl1", Title = "Polytechnic & Diploma Stream", Desc = "Hands-on technical education, engineering diplomas, and vocational training fields.", Tags = "diploma,tech,polytech,vocational", StreamType = "After10th, After12th, AfterGraduation", Icon = "briefcase", Color = "amber" },
            new { Id = "swi-lvl1", Title = "Career Switch & Transition", Desc = "Focuses on retraining and transition fields for working professionals.", Tags = "switch,tech,business,creative", StreamType = "AfterGraduation, CareerSwitch", Icon = "git-pull-request", Color = "rose" },
            new { Id = "enh-lvl1", Title = "Skill Enhancement", Desc = "Focuses on modern micro-credentials, certifications, and upskilling tracks.", Tags = "skill,tech,business,future", StreamType = "AfterGraduation, SkillEnhancement", Icon = "trending-up", Color = "cyan" }
        };

        foreach (var s in streams)
        {
            var p1 = new CareerPath
            {
                Id = s.Id,
                Title = s.Title,
                Description = s.Desc,
                Level = 1,
                ParentCareerId = null,
                StreamType = s.StreamType,
                Tags = s.Tags,
                FutureScope = "High demand in " + s.Title + " driven by global trends and industry growth.",
                DemandIndex = 80.0,
                Icon = s.Icon,
                Color = s.Color,
                SkillsRequired = "[\"Basic Logic\", \"Communication\"]",
                SalaryDataJson = "{\"Starting\": 300000, \"Mid-Career\": 700000, \"Senior\": 1500000}",
                IndustryGrowth = 10.0,
                RoadmapJson = "[{\"phase\":\"Foundations\",\"duration\":\"1-2 Years\",\"topics\":[\"Basic concepts of " + s.Title + "\"],\"projectSuggestion\":\"Create a simple report detailing introductory topics.\"}]",
                Certifications = "None",
                Colleges = "Various local institutes",
                WhatYouWillStudy = "Introduction to core principles of " + s.Title,
                RecommendedSubjects = "[\"Language\", \"Mathematics\"]",
                TopCompanies = "[\"General Enterprises\"]",
                RequiredDegrees = "[\"Secondary School Certificate\"]",
                WorkEnvironment = "Office",
                RemoteWorkPossibility = 20.0,
                EntrepreneurshipPotential = 30.0,
                CareerFlexibility = 40.0,
                LearningResources = "[\"Standard textbooks\"]",
                YoutubeResources = "[\"Introductory educational channels\"]",
                RoadmapTimeline = "1-2 Years",
                DifficultyLevel = "Medium",
                PersonalityMatch = "ESTJ, ESFJ",
                RelatedCareerIds = "",
                AutomationRisk = 25.0
            };
            allPaths.Add(p1);

            // Level 2: Subdomains (5 per stream)
            for (int i = 1; i <= 5; i++)
            {
                string sTitle = GetSubdomainTitle(s.Id, i);
                string sTag = GetSubdomainTag(s.Id, i);
                string sdId = $"{s.Id}-sd{i}";

                var p2 = new CareerPath
                {
                    Id = sdId,
                    Title = sTitle,
                    Description = "Gateway domain focusing on " + sTitle + " theoretical and practical aspects.",
                    Level = 2,
                    ParentCareerId = s.Id,
                    StreamType = s.StreamType,
                    Tags = s.Tags + "," + sTag,
                    FutureScope = "Gateway for specialized studies in " + sTitle + ".",
                    DemandIndex = 82.0,
                    Icon = s.Icon,
                    Color = s.Color,
                    SkillsRequired = "[\"Problem Solving\", \"Data Interpretation\"]",
                    SalaryDataJson = "{\"Starting\": 350000, \"Mid-Career\": 800000, \"Senior\": 1800000}",
                    IndustryGrowth = 11.0,
                    RoadmapJson = "[{\"phase\":\"Subdomain Core\",\"duration\":\"1 Year\",\"topics\":[\"Fundamentals of " + sTitle + "\"],\"projectSuggestion\":\"Build a case study analyzing " + sTitle + ".\"}]",
                    Certifications = "Foundational certificates",
                    Colleges = "State universities",
                    WhatYouWillStudy = "Intermediate concepts of " + sTitle,
                    RecommendedSubjects = "[\"Domain basics\"]",
                    TopCompanies = "[\"Industry Leaders\"]",
                    RequiredDegrees = "[\"Higher Secondary School Certificate\"]",
                    WorkEnvironment = "Office",
                    RemoteWorkPossibility = 30.0,
                    EntrepreneurshipPotential = 35.0,
                    CareerFlexibility = 45.0,
                    LearningResources = "[\"Online tutorials\", \"Industry blogs\"]",
                    YoutubeResources = "[\"Disciplinary channels\"]",
                    RoadmapTimeline = "2 Years",
                    DifficultyLevel = "Medium",
                    PersonalityMatch = "INTJ, ISTJ",
                    RelatedCareerIds = "",
                    AutomationRisk = 20.0
                };
                allPaths.Add(p2);

                // Level 3: Fields (3 per subdomain)
                for (int j = 1; j <= 3; j++)
                {
                    string fTitle = GetFieldTitle(sdId, j);
                    string fTag = GetFieldTag(sdId, j);
                    string fId = $"{sdId}-f{j}";

                    var p3 = new CareerPath
                    {
                        Id = fId,
                        Title = fTitle,
                        Description = "Applied study and practice of " + fTitle + " in modern industry.",
                        Level = 3,
                        ParentCareerId = sdId,
                        StreamType = s.StreamType,
                        Tags = p2.Tags + "," + fTag,
                        FutureScope = "Expanding scope in " + fTitle + " driven by modern innovation.",
                        DemandIndex = 85.0,
                        Icon = "cpu",
                        Color = s.Color,
                        SkillsRequired = "[\"Core tools\", \"Logical flow\"]",
                        SalaryDataJson = "{\"Starting\": 450000, \"Mid-Career\": 1000000, \"Senior\": 2200000}",
                        IndustryGrowth = 12.5,
                        RoadmapJson = "[{\"phase\":\"Core Field\",\"duration\":\"1 Year\",\"topics\":[\"Core topics in " + fTitle + "\"],\"projectSuggestion\":\"Deploy a prototype applying " + fTitle + " logic.\"}]",
                        Certifications = "Professional level certificates",
                        Colleges = "Top regional colleges",
                        WhatYouWillStudy = "Core professional aspects of " + fTitle,
                        RecommendedSubjects = "[\"Specialized domain\"]",
                        TopCompanies = "[\"TechCorp\", \"FinSolutions\", \"DesignStudio\"]",
                        RequiredDegrees = "[\"Bachelor's Degree\"]",
                        WorkEnvironment = "Hybrid",
                        RemoteWorkPossibility = 45.0,
                        EntrepreneurshipPotential = 50.0,
                        CareerFlexibility = 55.0,
                        LearningResources = "[\"Professional manuals\", \"Online courses\"]",
                        YoutubeResources = "[\"Technical tutorials\"]",
                        RoadmapTimeline = "3-4 Years",
                        DifficultyLevel = "Hard",
                        PersonalityMatch = "INFJ, ENFP",
                        RelatedCareerIds = "",
                        AutomationRisk = 15.0
                    };
                    allPaths.Add(p3);

                    // Level 4: Specializations (3 per field)
                    for (int k = 1; k <= 3; k++)
                    {
                        string spTitle = GetSpecializationTitle(fId, k);
                        string spTag = GetSpecializationTag(fId, k);
                        string spId = $"{fId}-s{k}";

                        var p4 = new CareerPath
                        {
                            Id = spId,
                            Title = spTitle,
                            Description = "Specialized career track focusing on advanced skills in " + spTitle + ".",
                            Level = 4,
                            ParentCareerId = fId,
                            StreamType = s.StreamType,
                            Tags = p3.Tags + "," + spTag,
                            FutureScope = "Highly sought-after specialization with rising job opportunities.",
                            DemandIndex = 90.0,
                            Icon = "code",
                            Color = s.Color,
                            SkillsRequired = "[\"Advanced tools\", \"Systems build\"]",
                            SalaryDataJson = "{\"Starting\": 550000, \"Mid-Career\": 1200000, \"Senior\": 2500000}",
                            IndustryGrowth = 14.5,
                            RoadmapJson = "[{\"phase\":\"Specialized concepts\",\"duration\":\"6 Months\",\"topics\":[\"Advanced systems in " + spTitle + "\"],\"projectSuggestion\":\"Build a complex production-ready application of " + spTitle + ".\"}]",
                            Certifications = "Industry standard credentials",
                            Colleges = "National level institutes",
                            WhatYouWillStudy = "Advanced practices in " + spTitle,
                            RecommendedSubjects = "[\"System theory\"]",
                            TopCompanies = "[\"Google\", \"Microsoft\", \"Meta\", \"Amazon\"]",
                            RequiredDegrees = "[\"Bachelor's / Master's Degree\"]",
                            WorkEnvironment = "Hybrid",
                            RemoteWorkPossibility = 60.0,
                            EntrepreneurshipPotential = 60.0,
                            CareerFlexibility = 65.0,
                            LearningResources = "[\"Advanced textbooks\", \"Research papers\"]",
                            YoutubeResources = "[\"Industry expert channels\"]",
                            RoadmapTimeline = "4 Years",
                            DifficultyLevel = "Hard",
                            PersonalityMatch = "INTP, INTJ",
                            RelatedCareerIds = "",
                            AutomationRisk = 10.0
                        };
                        allPaths.Add(p4);

                        // Level 5: Job Roles (4 per specialization)
                        for (int m = 1; m <= 4; m++)
                        {
                            string rTitle = GetJobRoleTitle(spId, m);
                            string rTag = GetJobRoleTag(spId, m);
                            string rId = $"{spId}-r{m}";

                            var p5 = new CareerPath
                            {
                                Id = rId,
                                Title = rTitle,
                                Description = "Elite production role. Responsible for delivery, architecture, and scaling of " + rTitle + " solutions.",
                                Level = 5,
                                ParentCareerId = spId,
                                StreamType = s.StreamType,
                                Tags = p4.Tags + "," + rTag,
                                FutureScope = "Top tier job role with high market demand and excellent long term growth.",
                                DemandIndex = 95.0,
                                Icon = "sparkles",
                                Color = s.Color,
                                SkillsRequired = "[\"Expert tools\", \"Scaling infrastructure\", \"System architecture\"]",
                                SalaryDataJson = "{\"Starting\": 700000, \"Mid-Career\": 1500000, \"Senior\": 3000000}",
                                IndustryGrowth = 18.5,
                                RoadmapJson = "[{\"phase\":\"Job Preparation\",\"duration\":\"3-6 Months\",\"topics\":[\"Practical deployment of " + rTitle + "\"],\"projectSuggestion\":\"Deploy a public-facing system demonstrating expert-level implementation of " + rTitle + ".\"}]",
                                Certifications = "Professional expert certifications",
                                Colleges = "IITs, IIMs, IISc, top global universities",
                                WhatYouWillStudy = "Industrial workflows and production scaling for " + rTitle,
                                RecommendedSubjects = "[\"Advanced Industry Workflows\"]",
                                TopCompanies = "[\"Top Tech MNCs\", \"Fortune 500 Enterprises\"]",
                                RequiredDegrees = "[\"B.Tech/M.Tech\", \"B.Sc/M.Sc\", \"MBA\"]",
                                WorkEnvironment = "Remote",
                                RemoteWorkPossibility = 80.0,
                                EntrepreneurshipPotential = 70.0,
                                CareerFlexibility = 75.0,
                                LearningResources = "[\"Documentation sites\", \"Expert courses\", \"Case studies\"]",
                                YoutubeResources = "[\"Tech conferences\", \"Project walkthrough channels\"]",
                                RoadmapTimeline = "4-5 Years",
                                DifficultyLevel = "Extremely Hard",
                                PersonalityMatch = "INTJ, ENTJ, ENTP",
                                RelatedCareerIds = "",
                                AutomationRisk = 5.0
                            };
                            allPaths.Add(p5);
                        }
                    }
                }
            }
        }

        // Set RelatedCareerIds based on sibling nodes in level 5 or level 4
        var level5Paths = allPaths.Where(p => p.Level == 5).ToList();
        for (int i = 0; i < level5Paths.Count; i++)
        {
            var p = level5Paths[i];
            var siblings = level5Paths.Where(x => x.ParentCareerId == p.ParentCareerId && x.Id != p.Id).Select(x => x.Id).ToList();
            p.RelatedCareerIds = string.Join(",", siblings);
        }

        // Save in batches to make Entity Framework seeding blazing fast
        context.ChangeTracker.AutoDetectChangesEnabled = false;
        int batchSize = 100;
        for (int i = 0; i < allPaths.Count; i += batchSize)
        {
            var batch = allPaths.Skip(i).Take(batchSize);
            context.CareerPaths.AddRange(batch);
            await context.SaveChangesAsync();
        }
        context.ChangeTracker.AutoDetectChangesEnabled = true;
    }

    private static string GetSubdomainTitle(string streamId, int index)
    {
        string p = streamId.Split('-')[0];
        if (p == "sci")
        {
            return index switch {
                1 => "PCM (Physics, Chemistry, Maths)",
                2 => "PCB (Physics, Chemistry, Biology)",
                3 => "Biotechnology & Genetics",
                4 => "Environmental & Climate Sciences",
                _ => "Astronomy & Astrophysics"
            };
        }
        if (p == "com")
        {
            return index switch {
                1 => "Financial Markets & Banking",
                2 => "Corporate Accounting & Tax",
                3 => "Business Management & Operations",
                4 => "E-Commerce & Digital Trade",
                _ => "International Trade & Economics"
            };
        }
        if (p == "art")
        {
            return index switch {
                1 => "Visual Arts & Graphic Design",
                2 => "Humanities & Social Sciences",
                3 => "Journalism & Mass Media",
                4 => "Law & Legal Studies",
                _ => "Creative Writing & Literature"
            };
        }
        if (p == "dip")
        {
            return index switch {
                1 => "Polytechnic Engineering",
                2 => "Medical Lab Technology",
                3 => "Vocational Trades",
                4 => "Office Administration & Helpdesk",
                _ => "Logistics & Warehouse Operations"
            };
        }
        if (p == "swi")
        {
            return index switch {
                1 => "Switching to Software Engineering",
                2 => "Switching to Project Management",
                3 => "Switching to UI/UX Design",
                4 => "Switching to Digital Content",
                _ => "Switching to Education"
            };
        }
        // enh
        return index switch {
            1 => "Advanced Coding & Scaling",
            2 => "Product & Team Leadership",
            3 => "AI & Machine Learning Systems",
            4 => "Corporate Sales & Negotiation",
            _ => "Emerging Future Careers"
        };
    }

    private static string GetSubdomainTag(string streamId, int index)
    {
        string p = streamId.Split('-')[0];
        return $"{p}-sd{index}";
    }

    private static string GetFieldTitle(string subdomainId, int index)
