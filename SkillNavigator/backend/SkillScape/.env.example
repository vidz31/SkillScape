# Groq API Configuration (Primary AI Provider - Fast Inference)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Configuration (Fallback AI Provider)
# Get your key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AI Configuration
# Set to 'groq' or 'openai' to specify primary provider
AI_PROVIDER=groq

